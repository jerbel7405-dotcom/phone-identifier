name: Build Windows EXE

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: windows-latest

    steps:
      - name: Récupérer le code
        uses: actions/checkout@v4

      - name: Installer Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Installer les dépendances
        run: |
          pip install phonenumbers pyinstaller

      - name: Compiler en .exe
        run: |
          pyinstaller --onefile --windowed --name "PhoneIdentifier" phone-identifier/phone_identifier.py

      - name: Publier le .exe
        uses: actions/upload-artifact@v4
        with:
          name: PhoneIdentifier-Windows
          path: dist/PhoneIdentifier.exe
